# ClinIQ — Root Environment Configuration
# Copy this file to .env and update values for your environment.
# Docker Compose reads variables from this file automatically.
#
# SECURITY: Never commit .env to version control.
#           This .env.example contains only placeholder values.

# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=cliniq_dev
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=cliniq

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=changeme_in_production

# ============================================
# MinIO (S3-compatible object storage)
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_in_production

# ============================================
# Backend Application
# ============================================
# See backend/.env.example for the full backend configuration.
# Key overrides for Docker Compose:
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
SECRET_KEY=changeme-use-openssl-rand-hex-32

# ============================================
# Frontend
# ============================================
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ============================================
# MLflow
# ============================================
MLFLOW_TRACKING_URI=http://mlflow:5000

# ============================================
# Monitoring
# ============================================
GF_SECURITY_ADMIN_PASSWORD=changeme_in_production
