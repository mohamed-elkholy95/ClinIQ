# ClinIQ Environment Configuration
# Copy this file to .env and update values

# Application
APP_NAME=ClinIQ
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://cliniq:cliniq@localhost:5432/cliniq
DATABASE_SYNC_URL=postgresql://cliniq:cliniq@localhost:5432/cliniq
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY_HEADER=X-API-Key

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=86400

# ML Models
MODEL_DIR=models
MODEL_CACHE_SIZE=3
INFERENCE_TIMEOUT=30
MAX_DOCUMENT_LENGTH=100000
MAX_BATCH_SIZE=100

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cliniq

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cliniq
MINIO_SECURE=false

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
