          }
        }
      }
    },
    {
      "title": "Confidence Drift per Model",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "avg by (model) (cliniq_drift_confidence_shift)",
          "legendFormat": "{{model}}"
