          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }
      }
    },
    {
      "title": "NER Entity Type Distribution",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 23 },
      "targets": [
        {
          "expr": "sum by (entity_type) (cliniq_ner_entities_total)",
