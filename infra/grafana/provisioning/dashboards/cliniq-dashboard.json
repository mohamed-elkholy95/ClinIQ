          "legendFormat": "{{ model }} p99",
          "refId": "C"
        }
      ],
      "title": "ML Inference Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
