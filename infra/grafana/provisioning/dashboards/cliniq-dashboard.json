          "legendFormat": "{{ model }} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ml_inference_duration_seconds_bucket{job=\"cliniq-api\"}[5m])) by (le, model))",
          "legendFormat": "{{ model }} p95",
          "refId": "B"
        },
        {
